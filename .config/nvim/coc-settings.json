{
  //Pyright settings
  "pyright.inlayHints.functionReturnTypes": false,
  "pyright.inlayHints.variableTypes": false,
  "prettier.tabWidth": 2,
  "python.formatting.provider": "black",
  // Typescript server settings
  "tsserver.implicitProjectConfig.strictNullChecks": true,
  "tsserver.implicitProjectConfig.strictFunctionTypes": true,
  // GoLang
  "go.checkForUpdates": "install",
  // CPP
  "clangd.path": "~/.config/coc/extensions/coc-clangd-data/install/16.0.2/clangd_16.0.2/bin/clangd",
  "languageserver": {
    "terraform": {
      "command": "terraform-ls",
      "filetypes": ["hcl", "terraform"],
      "args": ["serve"]
    }
  }
}
